{
  "name": "runewood",
  "version": "0.0.0",
  "description": "Gource-inspired, framework-agnostic WebGL visualization of live agent and repository activity",
  "keywords": [
    "visualization",
    "webgl",
    "gource",
    "file-tree",
    "agent",
    "activity",
    "replay"
  ],
  "homepage": "https://github.com/JalapenoLabs/runewood#readme",
  "bugs": "https://github.com/JalapenoLabs/runewood/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JalapenoLabs/runewood.git"
  },
  "license": "MIT",
  "author": "Jalapeno Labs",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "release": "release-it"
  },
  "devDependencies": {
    "@jalapenolabs/cli": "https://github.com/jalapenolabs/cli.git",
    "eslint": "9.31.0",
    "jiti": "^2.7.0",
    "release-it": "^20.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
